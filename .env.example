# ── Provider selection ────────────────────────────────────────────────────────
# "local" uses the stt/llm/tts Docker containers (no API keys needed).
# Swap any to a cloud provider and set the corresponding key below.
STT_PROVIDER=local   # local | deepgram | openai
LLM_PROVIDER=local   # local | anthropic | openai
TTS_PROVIDER=local   # local | cartesia  | openai

# ── Local model overrides (only used when *_PROVIDER=local) ───────────────────
# OLLAMA_MODEL=smollm2:135m   # default; try llama3.2:1b for better quality

# ── Cloud API keys (only needed when using cloud providers) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ── Optional cloud model/voice overrides ─────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_VOICE=alloy
# CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# ── Asterisk NAT ──────────────────────────────────────────────────────────────
# IP Asterisk advertises in SDP so baresip can reach Docker's RTP port mappings.
# Defaults to 127.0.0.1 (same-machine). Set to your LAN IP if baresip is on a
# different host.  macOS: ipconfig getifaddr en0
ASTERISK_EXTERNAL_IP=127.0.0.1

# ── AudioSocket server ────────────────────────────────────────────────────────
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9099

# ── Logging ───────────────────────────────────────────────────────────────────
LOGURU_LEVEL=INFO
