# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ── Agent selection ────────────────────────────────────────────────────────────
# Slug must match a row in the agents table. Change via admin UI without restart.
AGENT_SLUG=basic

# ── Infrastructure ────────────────────────────────────────────────────────────
# Set a strong password — used for the local Postgres container only.
POSTGRES_PASSWORD=
REDIS_URL=redis://redis:6379/0
CONFIG_API_URL=http://config-api:8080

# ── Cloud API keys ─────────────────────────────────────────────────────────────
# Only needed when using cloud providers (configured per-agent in the admin UI).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ── Asterisk NAT ──────────────────────────────────────────────────────────────
# IP Asterisk advertises in SDP so the softphone can reach Docker's RTP ports.
# Defaults to 127.0.0.1 (same machine). Set to your LAN IP if softphone is remote.
#   macOS: ipconfig getifaddr en0
ASTERISK_EXTERNAL_IP=127.0.0.1

# ── AudioSocket server ────────────────────────────────────────────────────────
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9099

# ── Logging ───────────────────────────────────────────────────────────────────
LOGURU_LEVEL=INFO
