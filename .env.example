# ── STT ───────────────────────────────────────────────────────────────────────
# Using Deepgram (default). Swap for any Pipecat-compatible STT service.
DEEPGRAM_API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── TTS ───────────────────────────────────────────────────────────────────────
# Using Cartesia (default). Swap for any Pipecat-compatible TTS service.
CARTESIA_API_KEY=

# ── AudioSocket server ────────────────────────────────────────────────────────
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9099

# ── Logging ───────────────────────────────────────────────────────────────────
LOGURU_LEVEL=INFO
