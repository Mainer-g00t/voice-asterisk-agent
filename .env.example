# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ── Agent selection ────────────────────────────────────────────────────────────
# Which agent the default container (docker compose up agent) serves.
# Change per-agent settings (prompt, provider, flow) live in the admin UI — no restart needed.
AGENT_SLUG=basic

# ── Infrastructure ────────────────────────────────────────────────────────────
# Use a strong random password — only needed for the local Postgres container.
POSTGRES_PASSWORD=
REDIS_URL=redis://redis:6379/0
CONFIG_API_URL=http://config-api:8080

# ── Cloud API keys ─────────────────────────────────────────────────────────────
# Select which provider to use per-agent in Admin UI → Agents → edit.
# Leave blank to use local models only (Whisper STT, Ollama LLM, Piper TTS — no key needed).
# Note: smollm2:135m (local default) does NOT support tool calling.
#   Use llama3.2:3b or a cloud LLM for agents with tools: docker compose exec llm ollama pull llama3.2:3b
ANTHROPIC_API_KEY=    # console.anthropic.com/settings/keys
OPENAI_API_KEY=       # platform.openai.com/api-keys
DEEPGRAM_API_KEY=     # console.deepgram.com/project/.../api-keys
CARTESIA_API_KEY=     # play.cartesia.ai/settings

# ── Asterisk NAT ──────────────────────────────────────────────────────────────
# IP Asterisk advertises in SDP so the softphone can reach Docker's RTP ports.
# Must be your Mac's LAN IP when the softphone is on a different machine.
# baresip also requires the LAN IP (not 127.0.0.1) — it can't route SIP to loopback.
#   macOS: ipconfig getifaddr en0
ASTERISK_EXTERNAL_IP=127.0.0.1

# ── AudioSocket server ────────────────────────────────────────────────────────
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9099

# ── Outbound calls ────────────────────────────────────────────────────────────
# AMI secret must match the value substituted into asterisk/manager.conf.tmpl at startup.
AMI_SECRET=voiceai_ami_secret
# {destination} is replaced with the value from POST /api/outbound/originate.
# Local softphone test: PJSIP/{destination}  →  destination="softphone" rings the softphone
# SIP trunk (real numbers): PJSIP/{destination}@my-trunk
OUTBOUND_CHANNEL_FORMAT=PJSIP/{destination}

# ── Monitoring ────────────────────────────────────────────────────────────────
# Grafana: http://localhost:3000  Prometheus: http://localhost:9091
# Defaults to "admin" if not set.
GRAFANA_PASSWORD=

# ── Admin security ────────────────────────────────────────────────────────────
# Leave both blank in dev mode — the admin UI and API are fully open (no auth).
#
# ADMIN_PASSWORD: single-user password backdoor for the admin UI at /admin/login.
ADMIN_PASSWORD=
# API_KEY: global admin-level REST key (X-Api-Key header). No owner filter — sees all data.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Enables multi-user mode — each GitHub account gets its own isolated workspace.
# Per-user scoped API keys (sk-va-...) also require this to be configured.
# 1. Create at: github.com/settings/developers → OAuth Apps
# 2. Set Homepage URL to BASE_URL and Callback URL to {BASE_URL}/admin/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Public URL of this service — used to build the OAuth callback redirect.
BASE_URL=http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: TRACE DEBUG INFO WARNING ERROR
LOGURU_LEVEL=INFO
